# --- Discord bot secrets (local dev only, never commit) ---
TOKEN=your-discord-bot-token
API_KEY=your-php-api-shared-key

# Optional: instant slash-command sync (single guild OR comma-separated list).
# This is your Discord COMMUNITY id (not an ARK server tag). Right-click your
# server icon in Discord (Developer Mode enabled) -> Copy Server ID.
#
# Single guild:    DEV_GUILD_ID=123456789012345678
# Multiple guilds: DEV_GUILD_ID=123456789012345678,987654321098765432
#
# Leave unset for a global sync (may take up to ~1 hour to appear).
